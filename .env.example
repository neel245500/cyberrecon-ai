# ==================== OLLAMA (Local LLM) ====================
# FREE, runs locally, no internet needed, slower but functional
# Setup: https://ollama.ai
#   1. Install Ollama
#   2. Run: ollama serve
#   3. In another terminal: ollama pull llama3

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ==================== OPENAI / CHATGPT API ====================
# OPTIONAL - For faster, more accurate AI analysis
# Get API key: https://platform.openai.com/api-keys (requires paid account)
# Cost: ~$0.05-0.25 per scan depending on findings count
# 
# If OPENAI_API_KEY is set, OpenAI will be used automatically.
# If not set, framework falls back to Ollama (if running).

OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ==================== DEEPSEEK API (Optional) ====================
# Alternative to OpenAI, open source, sometimes cheaper
# Get key: https://platform.deepseek.com

DEEPSEEK_API_KEY=

# ==================== GITHUB API TOKEN (Optional) ====================
# For higher GitHub API quota (60+ requests/hour)
# Not required for basic usage

GITHUB_TOKEN=
